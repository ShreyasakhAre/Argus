# ARGUS AI Service Configuration

# Demo Mode Settings
# Set to 'true' to enable demo mode with mock AI responses
USE_MOCK_AI=false

# AI Service Settings
# Timeout in milliseconds for external AI calls
AI_TIMEOUT=10000

# External AI API Configuration (Optional)
# Uncomment and configure if you want to use external AI services

# OpenAI Configuration
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-3.5-turbo

# HuggingFace Configuration
# HUGGINGFACE_API_KEY=your_huggingface_api_key_here
# HUGGINGFACE_MODEL=microsoft/DialoGPT-medium

# OpenRouter Configuration (Free models available)
# OPENROUTER_API_KEY=your_openrouter_api_key_here
# OPENROUTER_MODEL=mistralai/mistral-7b-instruct

# Fallback Configuration
# Enable/disable specific fallback features
ENABLE_URGENCY_DETECTION=true
ENABLE_FINANCIAL_DETECTION=true
ENABLE_SUSPICIOUS_DETECTION=true
ENABLE_LINK_DETECTION=true

# Logging Configuration
# Enable detailed AI service logging
AI_DEBUG_LOGGING=false

# Risk Score Thresholds
# Configure when alerts are automatically flagged
RISK_THRESHOLD_HIGH=70
RISK_THRESHOLD_MEDIUM=50
RISK_THRESHOLD_LOW=30

# Internal Email Domains
# Comma-separated list of internal email domains
INTERNAL_DOMAINS=company.com,internal.com,localhost,internal.local
